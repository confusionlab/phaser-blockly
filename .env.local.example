# Convex CLI target used by `pnpm exec convex dev` and `pnpm exec convex codegen`
CONVEX_DEPLOYMENT=dev:your-dev-deployment

# Optional single fallback used if mode-specific vars are not set:
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
# VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Development (used by `pnpm dev:*` / Vite dev mode)
VITE_CONVEX_URL_DEV=https://your-dev-deployment.convex.cloud
VITE_CONVEX_SITE_URL_DEV=https://your-dev-deployment.convex.site
VITE_CLERK_PUBLISHABLE_KEY_DEV=pk_test_...
# Optional: force desktop runtime to use PROD Clerk key during local Electron runs.
# VITE_DESKTOP_USE_PROD_CLERK_KEY=1

# Production build/runtime (used by `pnpm build` / Vite production mode)
VITE_CONVEX_URL_PROD=https://your-prod-deployment.convex.cloud
VITE_CONVEX_SITE_URL_PROD=https://your-prod-deployment.convex.site
VITE_CLERK_PUBLISHABLE_KEY_PROD=pk_live_...

# Optional single fallback used if mode-specific Clerk keys are not set:
# VITE_CLERK_PUBLISHABLE_KEY=pk_...
# Optional desktop-safe redirect used by Clerk in Electron runtime
VITE_DESKTOP_AUTH_REDIRECT_URL=https://accounts.confusionlab.com/
VITE_DESKTOP_AUTH_SIGN_IN_URL=https://accounts.confusionlab.com/sign-in
VITE_DESKTOP_AUTH_SIGN_UP_URL=https://accounts.confusionlab.com/sign-up

# Convex server env vars
# npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-clerk-issuer
# Optional secondary issuer during migrations (e.g., dev + prod Clerk side-by-side):
# npx convex env set CLERK_JWT_ISSUER_DOMAIN_SECONDARY https://your-second-clerk-issuer
# npx convex env set CLERK_WEBHOOK_SIGNING_SECRET whsec_...
# OpenAI assistant backend env:
# npx convex env set OPENAI_API_KEY sk-...
# npx convex env set OPENAI_ASSISTANT_MODEL gpt-4.1-mini
