# Optional single fallback used if mode-specific vars are not set:
# VITE_CONVEX_URL=https://your-deployment.convex.cloud
# VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Development (used by `pnpm dev:*` / Vite dev mode)
VITE_CONVEX_URL_DEV=https://your-dev-deployment.convex.cloud
VITE_CONVEX_SITE_URL_DEV=https://your-dev-deployment.convex.site
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_BILLING_PLAN_IDS=free_plan_id,creator_plan_id,pro_plan_id

# Production build/runtime (used by `pnpm build` / Vite production mode)
VITE_CONVEX_URL_PROD=https://your-prod-deployment.convex.cloud
VITE_CONVEX_SITE_URL_PROD=https://your-prod-deployment.convex.site
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Convex server env vars
# npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-clerk-issuer
# npx convex env set CLERK_WEBHOOK_SIGNING_SECRET whsec_...
# OpenRouter credentials are now server-side in Convex env vars:
# npx convex env set OPENROUTER_API_KEY sk-or-v1-...
# npx convex env set OPENROUTER_MODEL openai/gpt-5.3-codex
